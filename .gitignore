# ═══════════════════════════════════════════════════
# 🔐 PRINCESS PROJECT - .gitignore
# ═══════════════════════════════════════════════════

# ──────────────────────────────────────────────────
# 🔑 SECRETS & CREDENTIALS (NEVER COMMIT!)
# ──────────────────────────────────────────────────

# Environment variables
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
frontend/.env
frontend/.env.production

# Firebase credentials
*.json
!package.json
!package-lock.json
!tsconfig.json
!vercel.json
princess-project-*-firebase-adminsdk-*.json
backend/serviceAccountKey.json
backend/princess-project-*.json

# ──────────────────────────────────────────────────
# 📦 Dependencies
# ──────────────────────────────────────────────────

node_modules/
*/node_modules/
backend/node_modules/
frontend/node_modules/
package-lock.json (optionnel, peut être commit)

# ──────────────────────────────────────────────────
# 🏗️ Build Outputs
# ──────────────────────────────────────────────────

dist/
build/
.next/
out/
frontend/dist/
backend/dist/
*.tsbuildinfo

# ──────────────────────────────────────────────────
# 📝 Logs
# ──────────────────────────────────────────────────

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
backend/logs/
frontend/logs/

# ──────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ──────────────────────────────────────────────────

coverage/
.nyc_output/
*.lcov
.jest/

# ──────────────────────────────────────────────────
# 💻 IDE & Editors
# ──────────────────────────────────────────────────

.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
.sublime-project
.sublime-workspace

# ──────────────────────────────────────────────────
# 🖥️ OS Files
# ──────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ──────────────────────────────────────────────────
# 🔧 Misc
# ──────────────────────────────────────────────────

.cache/
.temp/
.tmp/
*.pid
*.seed
*.pid.lock
.pnp.*
.yarn-integrity

# ──────────────────────────────────────────────────
# 🚀 Deployment (keep configs, ignore local files)
# ──────────────────────────────────────────────────

.vercel
.netlify
.firebase

