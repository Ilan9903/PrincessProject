# ═══════════════════════════════════════════════════
# 🌐 FRONTEND - Variables d'Environnement (Template)
# ═══════════════════════════════════════════════════

# Backend API URL
# ⚠️ PAS de trailing slash (/) à la fin !

# ──────────────────────────────────────────────────
# 📍 DEVELOPMENT (Local)
# ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:2106

# ──────────────────────────────────────────────────
# 🚀 PRODUCTION (Render)
# ──────────────────────────────────────────────────
# VITE_API_URL=https://princess-backend.onrender.com

# ═══════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Copier ce fichier en `.env` pour development
# 2. Copier en `.env.production` avec URL production
# 3. NE JAMAIS commit les fichiers .env (uniquement .env.example)
# ═══════════════════════════════════════════════════
