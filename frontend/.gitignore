# ═══════════════════════════════════════════════════
# 🌐 FRONTEND - .gitignore
# ═══════════════════════════════════════════════════

# ──────────────────────────────────────────────────
# 🔑 SECRETS & CREDENTIALS (NEVER COMMIT!)
# ──────────────────────────────────────────────────

# Environment variables
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# ⚠️ IMPORTANT: .env.production contient VITE_API_URL
# Ce fichier PEUT être commité car il ne contient pas de secrets
# mais l'URL backend est publique de toute façon

# ──────────────────────────────────────────────────
# 📦 Dependencies
# ──────────────────────────────────────────────────

node_modules/

# ──────────────────────────────────────────────────
# 🏗️ Build Outputs (Vite)
# ──────────────────────────────────────────────────

dist/
dist-ssr/
build/
*.local
*.tsbuildinfo

# ──────────────────────────────────────────────────
# 📝 Logs
# ──────────────────────────────────────────────────

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ──────────────────────────────────────────────────

coverage/
.nyc_output/
*.lcov
.jest/

# ──────────────────────────────────────────────────
# 💻 IDE & Editors
# ──────────────────────────────────────────────────

.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ──────────────────────────────────────────────────
# 🖥️ OS Files
# ──────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ──────────────────────────────────────────────────
# 🔧 Misc
# ──────────────────────────────────────────────────

.cache/
.parcel-cache/
.temp/
.tmp/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock

# ──────────────────────────────────────────────────
# 🚀 Deployment & Frameworks
# ──────────────────────────────────────────────────

.vercel
.netlify
.next/
.nuxt/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port