# 🔐 Configuration Backend - Princess Project

# Port du serveur
PORT=2106

# 🔑 Sécurité
APP_PASSWORD=your_secure_password_here
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# 🔥 Firebase Configuration
FIREBASE_PROJECT_ID=princess-project-210622
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@princess-project.iam.gserviceaccount.com

# 🌐 CORS - Frontend URL
FRONTEND_URL=http://localhost:1308

# 🛠️ Environnement
NODE_ENV=development

# 📝 Notes:
# - Copier ce fichier en .env et remplir avec vos vraies valeurs
# - NE JAMAIS commit le fichier .env dans Git
# - Le JWT_SECRET doit faire au moins 32 caractères
# - Les clés Firebase sont dans le fichier JSON téléchargé depuis Firebase Console
